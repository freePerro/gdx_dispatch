# ═══════════════════════════════════════════════════════════════════════════════
# GDX Platform — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set for the app to start.
# Lines marked [optional] have sensible defaults or disable the feature if blank.
#
# NEVER commit .env to git — it contains secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────────────
# Environment name: production | development | testing
GDX_ENV=development
# App version tag (set by CI/CD, used in Sentry releases and health endpoint)
APP_VERSION=dev
# Build timestamp (set by CI/CD)
BUILD_TIME=unknown
# Log level for the FastAPI app
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL password — used to construct connection strings
POSTGRES_PASSWORD=your-db-password-here

# [REQUIRED] Control-plane database URL (Alembic migrations + app startup)
CONTROL_DATABASE_URL=postgresql://gdx:your-db-password-here@control-db:5432/gdx_control
# [REQUIRED] The single application database. Single-tenant collapse (Phase A):
# get_tenant_db() pins every request to this one DB — there is no per-tenant
# DB resolution any more.
DATABASE_URL=postgresql://gdx:your-db-password-here@control-db:5432/gdx

# Single-tenant identity (single-tenant collapse, Phase A). TenantMiddleware
# pins every request to this one tenant. GDX_TENANT_ID is what data-plane
# routers use as company_id (request.state.tenant["id"]), so it MUST equal
# GDX's company id in the data. Leave unset only in dev/tests (defaults to "gdx").
GDX_TENANT_ID=
GDX_TENANT_SLUG=gdx
GDX_TENANT_NAME=Example Garage Doors

# Initial admin account, seeded on first boot by the container entrypoint
# (see gdx_dispatch/tools/bootstrap_app.py). The account is created with
# must_change_password=True. If GDX_ADMIN_PASSWORD is left unset a random
# password is generated and printed to the container logs on first start.
GDX_ADMIN_EMAIL=admin@example.com
GDX_ADMIN_PASSWORD=

# PgBouncer URL for tenant connection pooling
PGBOUNCER_URL=postgresql://gdx:your-db-password-here@pgbouncer:5432/gdx_template

# Docker Compose DB passwords (for gdx/docker/docker-compose.yml)
CONTROL_DB_PASSWORD=your-control-db-password-here
TENANT_DB_PASSWORD=your-tenant-db-password-here

# Base URL for dynamically creating tenant databases
# (used by provisioning state machine — points to the PG server, not a specific DB)
TENANT_DB_BASE_URL=postgresql://gdx:your-db-password-here@control-db:5432
# Template database name to clone when provisioning new tenants
TENANT_TEMPLATE_DB=gdx_gdx_v2

# Fernet key for encrypting tenant DB URLs at rest — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# [optional] If blank, DB URLs are stored in plaintext (dev mode)
GDX_FERNET_KEY=

# S122-1: master key for the EncryptedString TypeDecorator (qb_token_store
# tokens, webhook_endpoint.secret, integrations.secret). Generate with the
# same Fernet snippet above. App refuses to boot in prod-like envs when this
# is unset (override with GDX_ENV=dev). DISTINCT from GDX_FERNET_KEY — they
# feed different encryption paths and rotate independently.
MASTER_ENCRYPTION_KEY=

# ── Redis ────────────────────────────────────────────────────────────────────
# [optional] Full Redis URL (used by auth, circuit breaker, idempotency, SLA monitor, etc.)
REDIS_URL=redis://redis:6379/0

# Celery broker and result backend (default to separate Redis DBs)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TIMEZONE=UTC

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# [REQUIRED] Secret key for the FastAPI app (session signing, CSRF)
SECRET_KEY=generate-a-random-64-char-hex-string

# JWT signing — RS256 (preferred) or HS256 fallback
# For RS256: paste the PEM-encoded keys with literal \n for newlines
RS_PRIVATE_KEY=
RS_PUBLIC_KEY=
# HS256 fallback: used only if RS_PRIVATE_KEY is empty
JWT_SECRET=dev-secret-change-in-production

# [optional] Admin API token for control-plane endpoints (billing portal, feature flags, etc.)
ADMIN_API_TOKEN=

# [optional] E2E test bypass — set to "1" to allow x-e2e-test header to skip auth
GDX_E2E_BYPASS=0

# Authentik (SS-1 foundation)
# Generate fresh values in production:
#   openssl rand -base64 60   # AUTHENTIK_SECRET_KEY
#   openssl rand -base64 32   # AUTHENTIK_POSTGRES_PASSWORD
#   openssl rand -base64 32   # AUTHENTIK_BOOTSTRAP_TOKEN (remove after first admin login)
AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRES_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=

# ── Cloudflare Turnstile (public lead intake) ──────────────────────────────
# Server-side secret for turnstile siteverify; required for /api/v1/landing-leads
# to enforce the bot challenge. If unset, the route fails-open (dev mode).
# Sitekey lives in marketing-site env (publishable). Optional hostname pin
# rejects siteverify responses where Cloudflare reports a different host.
TURNSTILE_SECRET=
TURNSTILE_HOSTNAME=

# ── Stripe (Billing & Payments) ─────────────────────────────────────────────
# Get keys at dashboard.stripe.com -> Developers -> API keys
# [optional] Leave blank to disable Stripe-dependent features
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here
# Stripe Connect webhook (falls back to STRIPE_WEBHOOK_SECRET if blank)
STRIPE_CONNECT_WEBHOOK_SECRET=

# Price IDs for subscription tiers (create in Stripe dashboard)
STRIPE_PRICE_ID=price_your-default-price-id
STRIPE_PRICE_STARTER=price_starter_xxx
STRIPE_PRICE_PROFESSIONAL=price_professional_xxx
STRIPE_PRICE_ENTERPRISE=price_enterprise_xxx
# Trial days before card is required (default: 14)
STRIPE_TRIAL_DAYS=14
# Return URL after Stripe billing portal session
STRIPE_PORTAL_RETURN_URL=https://app.example.com/billing

# ── QuickBooks Online ────────────────────────────────────────────────────────
# Create an app at developer.intuit.com -> OAuth 2.0 credentials
# [optional] Leave blank to disable QuickBooks integration
QB_CLIENT_ID=your-qbo-client-id
QB_CLIENT_SECRET=your-qbo-client-secret
QB_REDIRECT_URI=https://yourdomain.com/api/qb/oauth/callback
QB_ENVIRONMENT=production
# Webhook verifier token from QBO developer console
QB_WEBHOOK_VERIFIER_TOKEN=your-qbo-webhook-verifier-token
# Newer webhook router uses this key name
QB_WEBHOOK_SECRET=

# ── Google ───────────────────────────────────────────────────────────────────
# Google Maps API key (geocoding, routing, dispatch scheduling)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google SSO (for Google login via /sso endpoints)
GOOGLE_SSO_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SSO_CLIENT_SECRET=your-google-client-secret
GOOGLE_SSO_REDIRECT_URI=https://yourdomain.com/api/sso/google/callback

# ── Microsoft SSO ────────────────────────────────────────────────────────────
# [optional] Microsoft/Azure AD SSO
MICROSOFT_SSO_CLIENT_ID=
MICROSOFT_SSO_CLIENT_SECRET=
MICROSOFT_SSO_REDIRECT_URI=
MICROSOFT_SSO_TENANT=common

# ── Twilio (SMS) ─────────────────────────────────────────────────────────────
# [optional] Leave blank to disable SMS features
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18181234567

# ── AI / LLM ────────────────────────────────────────────────────────────────
# OpenAI (used for voice transcription, AI copilot features)
# Cloud: set a real OPENAI_API_KEY and leave OPENAI_BASE_URL blank
# Local: point OPENAI_BASE_URL to llama-swap and set OPENAI_MODEL to a local model
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
MAX_COMPLETION_TOKENS=8192

# Anthropic (AI Copilot / expert assistant)
# [optional] Leave blank to disable Anthropic-powered features
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Local LLM (optional, for local AI features)
LOCAL_AI_URL=http://localhost:11430/v1/chat/completions
LOCAL_MODEL=gemma-4:26b-a4b

# HuggingFace token (for model downloads in R&D tools)
HF_TOKEN=

# ── Email (Platform SMTP — used by signup, auth, password reset) ─────────────
# [optional] Leave blank to disable outbound email
PLATFORM_SMTP_HOST=smtp.titan.email
PLATFORM_SMTP_PORT=465
PLATFORM_SMTP_USER=info@example.com
PLATFORM_SMTP_PASS=your-smtp-password-here
PLATFORM_FROM_NAME=DispatchApp

# Per-tenant SMTP (admin settings panel — tenants configure their own)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
FROM_NAME=GDX
FROM_EMAIL=

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
# [optional] Leave blank to disable Sentry
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=gdx

# ── Cloudflare ───────────────────────────────────────────────────────────────
# [optional] Used by deploy scripts for cache purge and DNS for new tenants
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=your-zone-id-here

# ── Infrastructure ───────────────────────────────────────────────────────────
# VPS IP address (used for DNS record creation during tenant signup)
VPS_IP=203.0.113.10  # placeholder (RFC 5737)

# Base URLs
GDX_BASE_URL=https://gdx.example.com
SIGNUP_BASE_URL=https://example.com
# Secret code to bypass normal signup flow (leave blank to disable)
SIGNUP_BYPASS_CODE=

# Customer portal base URL (for generating portal invite links)
CUSTOMER_PORTAL_BASE_URL=https://portal.example.com
# Max age in days for public portal tokens
PUBLIC_TOKEN_MAX_AGE_DAYS=90

# Upload directories (container paths)
UPLOAD_DIR=/app/uploads
GDX_RESOURCE_DIR=/tmp/gdx-resources
MOBILE_UPLOAD_DIR=/tmp/gdx_mobile_uploads

# ── Log Shipping ─────────────────────────────────────────────────────────────
# [optional] Where to ship logs: stdout | s3 | cloudwatch
LOG_SHIP_TARGET=stdout
LOG_RETENTION_DAYS=90
LOG_S3_BUCKET=
AWS_REGION=us-east-1
LOG_CLOUDWATCH_GROUP=gdx-logs

# ── Monitoring (optional) ───────────────────────────────────────────────────
GRAFANA_PASSWORD=your-grafana-password-here

# ── Hostinger API ────────────────────────────────────────────────────────────
# [optional] Domain registration, DNS, VPS management
HOSTINGER_API_TOKEN=

# ── Power Apps / Dataverse (legacy, rarely used) ─────────────────────────────
POWER_APPS_TENANT_ID=
POWER_APPS_CLIENT_ID=
POWER_APPS_CLIENT_SECRET=
ENVIRONMENT_URL=
POWER_APPS_ENVIRONMENT_ID=

# ── CHI Portal (supplier integration) ────────────────────────────────────────
# [optional] Credentials for CHI overhead door supplier portal
CHI_USERNAME=
CHI_PASSWORD=

# ── Dev / Test Only ──────────────────────────────────────────────────────────
# These are NOT needed in production — only for local dev or CI
# Service account key for internal R&D tools (scanners, health checks).
# Mint with: python gdx/tools/service_account_mint.py mint --name rd-api-scanner \
#     --scopes read:* --all-tenants --created-by your.email@example.com
# Replaces the old PROD_ADMIN_EMAIL/PROD_ADMIN_PASSWORD pattern (removed 2026-04-13).
GDX_SVC_KEY=

# ── LLM helper API keys ─────────────────────────────────────────────────────
# Read by ~/.claude/local-llm-mcp.py at startup. Drives the /cerebras, /groq,
# /gemini skills. If empty, those skills return "X_API_KEY not configured"
# and the skill's dispatcher falls back to /gemma (local GPU) where possible.
# Get keys:
#   Cerebras:  https://cloud.cerebras.ai (free tier, qwen-3 235B)
#   Groq:      https://console.groq.com (free tier, Llama 3.3 70B)
#   Google:    https://aistudio.google.com/apikey (free tier, Gemini 2.0 Flash)
# After editing this file, restart Claude Code so the MCP subprocess re-reads.
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
GDX_E2E_EMAIL=
GDX_E2E_PASSWORD=
GDX_TENANT_ID=
GDX_LOAD_USERS=10
GDX_LOAD_DURATION=30
GDX_DEFAULT_TENANT_ID=

# Postgres MCP server (local dev tooling only)
POSTGRES_MCP_URL=

# Migration tooling (one-time use)
OLD_DB_URL=
NEW_DB_URL=
SOURCE_DB_URL=
TARGET_DB_URL=
GDX_CONTROL_DATABASE_URL=
