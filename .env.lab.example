# ═══════════════════════════════════════════════════════════════════════════════
# GDX Lab Environment — R430 LAN-local dev/test box
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.lab, fill the MUST-FILL section, then:
#   docker compose -f gdx/docker/docker-compose.yml --env-file .env.lab up -d
#
# Scope: only the 34 vars that gdx/docker/docker-compose.yml actually interpolates.
# Anything not listed here is either baked into the image, read by a different
# app (Command Center), or feature-gated and inert when blank.
#
# For the prod-oriented kitchen-sink template see .env.template (304 lines).
# ═══════════════════════════════════════════════════════════════════════════════


# ── MUST FILL — stack will not boot or will silently run degraded ────────────

# Postgres passwords. Pick anything for the lab — they don't need to match prod.
#   openssl rand -base64 24
CONTROL_DB_PASSWORD=
TENANT_DB_PASSWORD=

# The URL the app uses to create new tenant DBs during signup/provisioning.
# Must reference TENANT_DB_PASSWORD (above) — the two drift silently if edited
# independently, and tenant provisioning fails with no startup error.
# Format: postgresql://gdx:<TENANT_DB_PASSWORD>@pgbouncer:5432
TENANT_DB_BASE_URL=

# FastAPI session/CSRF signing.
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting tenant DB URLs at rest in the control plane.
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT signing. RS256 preferred — leave both RS_* blank to fall back to HS256.
# RS256 (recommended):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out /tmp/rs.key
#   openssl rsa -in /tmp/rs.key -pubout -out /tmp/rs.pub
#   Paste with literal \n between lines (single-line docker env var format).
RS_PRIVATE_KEY=
RS_PUBLIC_KEY=
# HS256 fallback — used only when RS_PRIVATE_KEY is blank.
JWT_SECRET=lab-only-change-for-prod

# Authentik (SS-1 identity foundation). All three MUST be set or authentik-server
# fails its healthcheck and the `app` service starts without an IdP behind it.
#   openssl rand -base64 60   # AUTHENTIK_SECRET_KEY
#   openssl rand -base64 32   # AUTHENTIK_POSTGRES_PASSWORD
#   openssl rand -base64 32   # AUTHENTIK_BOOTSTRAP_TOKEN (rotate after first login)
AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRES_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=

# Platform service account key — used by internal scanners, pollution_check,
# and any tool that needs control-plane scope outside a user session. Mint with:
#   .venv/bin/python gdx/tools/service_account_mint.py mint \
#     --name rd-api-scanner --scopes read:* --all-tenants \
#     --created-by owner@example.com
# Paste the full `svc_live_...` string. If blank, the scanner tools 401.
GDX_SVC_KEY=


# ── SAFE DEV DEFAULTS — pre-filled for lab; edit only if you know why ────────

ENVIRONMENT=development
APP_VERSION=lab
BUILD_TIME=fill-from-deploy-or-leave
GDX_E2E_BYPASS=1                         # allow test-email signups (prod = 0)
VPS_IP=127.0.0.1                         # lab isn't the VPS; prevents accidental DNS writes
GDX_BASE_URL=http://lab.home:8001        # adjust when LAN hostname is decided
SIGNUP_BASE_URL=http://lab.home:8001
QB_ENVIRONMENT=sandbox                   # prod uses "production" — never from lab
QB_REDIRECT_URI=http://lab.home:8001/api/qb/oauth/callback


# ── FEATURE-OFF — leave blank unless you have a reason ───────────────────────
# Each of these, when blank, disables its feature cleanly inside the app.
# Never copy prod secrets here — the lab should not be able to touch prod state.

CLOUDFLARE_API_TOKEN=                    # DON'T COPY PROD — would let lab purge prod CF cache
SENTRY_DSN=                              # separate project if you want lab errors tracked
STRIPE_SECRET_KEY=                       # use test keys (sk_test_...) if exercising billing
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
PLATFORM_SMTP_PASS=                      # blank = no outbound email from lab
SIGNUP_BYPASS_CODE=                      # set a short string if you want to bypass the signup bot gate


# ── COMPOSE-DEFAULTED — leave UNSET so compose baked-in defaults win ─────────
# These have hardcoded defaults in gdx/docker/docker-compose.yml. Setting them
# here would override compose's default — not what you want on the lab.
#
#   CLOUDFLARE_ZONE_ID         (prod zone ID — shouldn't apply to lab)
#   GOOGLE_MAPS_API_KEY        (has a redacted placeholder in compose)
#   QB_CLIENT_ID               (prod QB app — see note below)
#   QB_CLIENT_SECRET           (prod QB app — see note below)
#   QB_WEBHOOK_VERIFIER_TOKEN  (prod QB app — see note below)
#
# NOTE: QB_CLIENT_ID / QB_CLIENT_SECRET / QB_WEBHOOK_VERIFIER_TOKEN are
# hardcoded to PROD values in gdx/docker/docker-compose.yml. Until that's
# fixed upstream, the lab will share QB credentials with prod. Don't exercise
# QB flows on the lab until a sandbox QB app is wired in (logged as future
# cleanup — D-item to be filed).
