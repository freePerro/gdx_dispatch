{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gdx.vehicle.v1",
  "description": "Fleet vehicle assigned to a technician or tenant.",
  "type": "object",
  "required": ["vin", "make", "model", "year"],
  "properties": {
    "vin": {"type": "string", "minLength": 1, "maxLength": 32},
    "make": {"type": "string", "minLength": 1, "maxLength": 64},
    "model": {"type": "string", "minLength": 1, "maxLength": 64},
    "year": {"type": "integer", "minimum": 1900, "maximum": 2100},
    "license_plate": {"type": "string", "maxLength": 16},
    "assigned_tech_id": {"type": "string"},
    "odometer_miles": {"type": "integer", "minimum": 0},
    "notes": {"type": "string"}
  },
  "additionalProperties": false,
  "x-gdx-capabilities": [
    ["read", "vehicle"],
    ["write", "vehicle"]
  ],
  "x-gdx-index-hints": ["vin", "assigned_tech_id"]
}
