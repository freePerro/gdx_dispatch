# ─────────────────────────────────────────────────────────────────────────────
# GDX Dispatch — PUBLIC DEMO env (gdxdispatch.com)
#
# Copy to `.env.demo` on the VPS and fill the generated secrets. The real
# `.env.demo` is gitignored — NEVER commit filled secrets.
#
#   cp .env.demo.example .env.demo
#   bash gen-keys.sh >> .env.demo      # appends fresh SECRET_KEY/JWT/FERNET/etc.
#   # then edit DB_PASSWORD + GDX_ADMIN_PASSWORD below
#
# These keys are FRESH and demo-only — they share nothing with production.
# ─────────────────────────────────────────────────────────────────────────────

# Pin the image to the same release prod runs (one source of truth).
APP_VERSION=1.5.1

# Public URL — drives OAuth callbacks, links, cookie scoping.
GDX_BASE_URL=https://gdxdispatch.com

# Production-grade boot (no debug leakage). Requires all keys below to be set.
GDX_ENV=production

# Demo tenant identity (distinct from prod).
GDX_TENANT_SLUG=demo
GDX_TENANT_NAME=Demo Garage Doors
# Generate once:  python3 -c "import uuid; print(uuid.uuid4())"
GDX_TENANT_ID=REPLACE_WITH_UUID
GDX_DEFAULT_TENANT_ID=REPLACE_WITH_UUID

# ── Shared demo login (shown on the login screen) ───────────────────────────
GDX_ADMIN_EMAIL=demo@gdxdispatch.com
GDX_ADMIN_PASSWORD=REPLACE_WITH_DEMO_PASSWORD

# ── Database (demo-only, isolated volume) ───────────────────────────────────
DB_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# ── Required secrets — generate with gen-keys.sh ────────────────────────────
SECRET_KEY=REPLACE
JWT_SECRET=REPLACE
FERNET_KEY=REPLACE
GDX_FERNET_KEY=REPLACE
MASTER_ENCRYPTION_KEY=REPLACE

# ── Outbound integrations: ALL DISABLED (left empty = neutered no-op). ───────
# Do not fill these. Listed for documentation / audit only.
# Email:        PLATFORM_SMTP_PASS, POWER_APPS_TENANT_ID, POWER_APPS_CLIENT_ID,
#               GDX_MICROSOFT_SECRET_KEY, MICROSOFT_SSO_CLIENT_ID/SECRET
# SMS/voice:    TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER
# Billing:      STRIPE_SECRET_KEY, STRIPE_PUBLISHABLE_KEY, STRIPE_WEBHOOK_SECRET
# Accounting:   QB_CLIENT_ID, QB_CLIENT_SECRET, QB_WEBHOOK_VERIFIER_TOKEN
# SSO/maps:     GOOGLE_SSO_CLIENT_ID/SECRET, GOOGLE_MAPS_API_KEY
# Tenant DNS:   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ZONE_ID
